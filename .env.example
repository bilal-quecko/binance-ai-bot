# App
APP_NAME=binance-ai-bot
APP_ENV=dev
APP_MODE=paper
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000

# Trading defaults
SYMBOLS=BTCUSDT,ETHUSDT
TIMEFRAMES=1m,5m,15m
RISK_PER_TRADE=0.005
MAX_DAILY_LOSS=0.02
MAX_OPEN_POSITIONS=3
AI_ENABLED=false

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Storage
# Local SQLite state is stored under ./data so paper sessions, signal history,
# validation snapshots, and runtime recovery survive backend restarts.
DATABASE_URL=sqlite:///./data/binance_ai_bot.db
